NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Meta Pixel / Conversions API
NEXT_PUBLIC_META_PIXEL_ID=          # your Pixel ID (safe to expose)
META_PIXEL_ID=                      # same value — used server-side in CAPI route
META_CAPI_TOKEN=                    # System User access token from Meta Events Manager
META_TEST_EVENT_CODE=               # optional: TEST##### for Events Manager test tab

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=                  # your GTM container ID, e.g. GTM-XXXXXXX (safe to expose)

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=             # Clarity project ID (Clarity > Settings > Overview, safe to expose)
