# --- Production (CloudPanel VPS) ---
# Same-origin: API is reached at https://kamiabprokashon.xyz/api (the client appends /api itself)
NEXT_PUBLIC_API_URL=https://kamiabprokashon.xyz
NEXT_PUBLIC_SITE_URL=https://kamiabprokashon.xyz

# For local dev use instead:
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Meta Pixel / Conversions API
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
META_PIXEL_ID=your-pixel-id
META_CAPI_TOKEN=your-meta-capi-token
META_TEST_EVENT_CODE=

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=your-gtm-id

# Microsoft Clarity (project id from Clarity > Settings > Overview)
NEXT_PUBLIC_CLARITY_ID=t9zpen44wi
