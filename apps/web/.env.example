# --- Production (CloudPanel VPS) ---
# Same-origin: API is reached at https://shukhilife.com/api (the client appends /api itself)
NEXT_PUBLIC_API_URL=https://shukhilife.com
NEXT_PUBLIC_SITE_URL=https://shukhilife.com

# For local dev use instead:
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Meta Pixel / Conversions API
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
META_PIXEL_ID=your-pixel-id
META_CAPI_TOKEN=your-meta-capi-token
META_TEST_EVENT_CODE=

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=your-gtm-id
